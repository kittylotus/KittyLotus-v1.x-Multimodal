{
  "templateName": "Fantasy - Sealed Card",
  "templateAuthor": "KittyLotus",
  "templatePosition": "BOTTOM",
  "htmlTemplate": "<!-- TEMPLATE NAME: FantasyDocs — Sealed Letter (Seal Bottom, FC label, No “SEAL” text) -->\r\n<!-- POSITION: BOTTOM -->\r\n<!-- CARD_TEMPLATE_START -->\r\n\r\n<style>\r\n  #silly-sim-tracker-container{\r\n    display:flex; flex-direction:column; align-items:center;\r\n    gap:18px; width:100%; padding:18px 0;\r\n  }\r\n  .wide-wrapper-scope{ width:100%; display:flex; justify-content:center; }\r\n  .wide-container{\r\n    width:100%;\r\n    display:flex;\r\n    justify-content:center;\r\n    font-family: \"Times New Roman\", Times, serif;\r\n  }\r\n\r\n  /* ===== OUTER: dark wood desk ===== */\r\n  .fd-wrap{\r\n    width:min(100%, 640px);\r\n    min-width: 320px;\r\n    border-radius: 22px;\r\n    border: 1px solid rgba(255,255,255,.10);\r\n    background:\r\n      radial-gradient(circle at 20% 10%, rgba(0,0,0,.30), transparent 55%),\r\n      radial-gradient(circle at 80% 0%, rgba(0,0,0,.22), transparent 58%),\r\n      linear-gradient(180deg, rgba(42,28,18,.98), rgba(18,12,8,.98));\r\n    box-shadow: 0 22px 60px rgba(0,0,0,.50);\r\n    position:relative;\r\n    overflow:hidden;\r\n    padding: 14px;\r\n  }\r\n\r\n  .fd-wrap::before{\r\n    content:\"\";\r\n    position:absolute; inset:0;\r\n    background:\r\n      repeating-linear-gradient(90deg, rgba(255,255,255,.04) 0 1px, transparent 1px 18px),\r\n      repeating-linear-gradient(0deg, rgba(0,0,0,.10) 0 2px, transparent 2px 28px);\r\n    opacity:.10;\r\n    pointer-events:none;\r\n  }\r\n\r\n  /* ===== our checkbox ===== */\r\n  .toggle-wide{ display:none; }\r\n  .fd-body{ display:none; }\r\n  .toggle-wide:checked + .fd-wrap .fd-body{ display:block; }\r\n\r\n  /* ===== PARCHMENT LETTER ===== */\r\n  .letter{\r\n    position:relative;\r\n    border-radius: 18px;\r\n    border: 1px solid rgba(60,40,24,.35);\r\n    background:\r\n      radial-gradient(circle at 30% 18%, rgba(255,255,255,.55), transparent 48%),\r\n      radial-gradient(circle at 70% 85%, rgba(0,0,0,.08), transparent 55%),\r\n      linear-gradient(180deg, rgba(255,247,231,.96), rgba(244,232,206,.96));\r\n    box-shadow:\r\n      0 14px 36px rgba(0,0,0,.30),\r\n      0 0 0 1px rgba(255,255,255,.45) inset;\r\n    overflow:hidden;\r\n  }\r\n\r\n  .letter::before{\r\n    content:\"\";\r\n    position:absolute; inset:-40px;\r\n    background:\r\n      repeating-linear-gradient(0deg, rgba(0,0,0,.05) 0 1px, transparent 1px 7px),\r\n      radial-gradient(circle at 20% 40%, rgba(0,0,0,.06), transparent 45%),\r\n      radial-gradient(circle at 85% 25%, rgba(0,0,0,.05), transparent 50%);\r\n    opacity:.22;\r\n    pointer-events:none;\r\n    transform: rotate(-1.5deg);\r\n  }\r\n\r\n  /* ===== HEADER (compact preview) ===== */\r\n  .fd-head{\r\n    position:relative;\r\n    padding: 14px 14px 12px;\r\n    cursor:pointer;\r\n    user-select:none;\r\n    display:flex;\r\n    justify-content:space-between;\r\n    align-items:flex-start;\r\n    gap:12px;\r\n  }\r\n  .fd-head > :not(.fd-left):not(.fd-right){ display:none !important; }\r\n\r\n  .fd-left{ min-width:0; }\r\n  .fd-title{\r\n    font-weight: 800;\r\n    font-size: 15px;\r\n    letter-spacing:.02em;\r\n    color: rgba(35,24,16,.92);\r\n    white-space:nowrap;\r\n    overflow:hidden;\r\n    text-overflow:ellipsis;\r\n  }\r\n  .fd-meta{\r\n    margin-top:6px;\r\n    font-size:12px;\r\n    color: rgba(35,24,16,.62);\r\n    font-variant-numeric: tabular-nums;\r\n    white-space:nowrap;\r\n    overflow:hidden;\r\n    text-overflow:ellipsis;\r\n  }\r\n\r\n  .fd-right{\r\n    display:flex;\r\n    flex-direction:column;\r\n    align-items:flex-end;\r\n    gap:8px;\r\n    flex-shrink:0;\r\n  }\r\n  .fd-chip{\r\n    font-size:12px;\r\n    padding:7px 10px;\r\n    border-radius: 999px;\r\n    border: 1px solid rgba(60,40,24,.22);\r\n    background: rgba(255,255,255,.55);\r\n    color: rgba(35,24,16,.72);\r\n    white-space:nowrap;\r\n    box-shadow: 0 10px 22px rgba(0,0,0,.10);\r\n    max-width: 220px;\r\n    overflow:hidden;\r\n    text-overflow:ellipsis;\r\n  }\r\n\r\n  .flap-line{\r\n    height:1px;\r\n    background: linear-gradient(90deg, transparent, rgba(60,40,24,.22), transparent);\r\n    opacity:.95;\r\n  }\r\n\r\n  /* ===== COMPACT PREVIEW ===== */\r\n  .fd-preview{\r\n    padding: 10px 14px 14px;\r\n    color: rgba(35,24,16,.78);\r\n    font-size:12px;\r\n    line-height:1.35;\r\n  }\r\n  .fd-preview .line{\r\n    white-space:nowrap;\r\n    overflow:hidden;\r\n    text-overflow:ellipsis;\r\n    border-bottom: 1px dotted rgba(60,40,24,.18);\r\n    padding-bottom:6px;\r\n    margin-bottom:6px;\r\n  }\r\n  .fd-preview .line:last-child{\r\n    border-bottom:none;\r\n    margin-bottom:0;\r\n    padding-bottom:0;\r\n  }\r\n\r\n  /* ===== BODY (expanded) ===== */\r\n  .fd-body{\r\n    padding: 14px;\r\n  }\r\n\r\n  .rule{\r\n    height:1px;\r\n    margin: 0 0 12px;\r\n    background: repeating-linear-gradient(90deg, rgba(60,40,24,.22) 0 2px, transparent 2px 10px);\r\n    opacity:.55;\r\n  }\r\n\r\n  .letterblock{\r\n    border-radius: 14px;\r\n    border: 1px solid rgba(60,40,24,.20);\r\n    background: rgba(255,255,255,.55);\r\n    box-shadow: 0 10px 24px rgba(0,0,0,.12);\r\n    overflow:hidden;\r\n    margin-bottom: 12px;\r\n  }\r\n\r\n  .lb-hd{\r\n    padding: 10px 12px;\r\n    border-bottom: 1px solid rgba(60,40,24,.16);\r\n    background:\r\n      radial-gradient(circle at 25% 30%, rgba(255,255,255,.45), transparent 55%),\r\n      rgba(255,255,255,.50);\r\n    display:flex;\r\n    justify-content:space-between;\r\n    align-items:center;\r\n    gap:10px;\r\n  }\r\n  .lb-k{\r\n    font-size:11px;\r\n    letter-spacing:.10em;\r\n    text-transform:uppercase;\r\n    color: rgba(35,24,16,.62);\r\n    font-weight: 900;\r\n  }\r\n  .lb-tag{\r\n    font-size:12px;\r\n    padding:6px 10px;\r\n    border-radius: 999px;\r\n    border: 1px solid rgba(60,40,24,.18);\r\n    background: rgba(255,255,255,.55);\r\n    color: rgba(35,24,16,.70);\r\n    white-space:nowrap;\r\n    max-width: 220px;\r\n    overflow:hidden;\r\n    text-overflow:ellipsis;\r\n  }\r\n\r\n  .lb-bd{\r\n    padding: 10px 12px 12px;\r\n    font-size: 13px;\r\n    color: rgba(35,24,16,.88);\r\n    line-height:1.55;\r\n  }\r\n\r\n  /* “Blocky ledger” stats */\r\n  .grid{ display:grid; gap:0; }\r\n\r\n  .row{\r\n    display:grid;\r\n    grid-template-columns: 120px 1fr 50px;\r\n    gap:10px;\r\n    align-items:center;\r\n    padding: 10px 12px;\r\n    border-top: 1px solid rgba(60,40,24,.14);\r\n  }\r\n  .row:first-child{ border-top:none; }\r\n\r\n  .lab{\r\n    font-size:12px;\r\n    color: rgba(35,24,16,.62);\r\n    letter-spacing:.06em;\r\n    font-variant-numeric: tabular-nums;\r\n  }\r\n  .bar{\r\n    height: 10px;\r\n    border-radius: 3px;\r\n    background: rgba(60,40,24,.12);\r\n    overflow:hidden;\r\n    box-shadow: 0 0 0 1px rgba(255,255,255,.55) inset;\r\n  }\r\n  .fill{\r\n    height:100%;\r\n    width: min(100%, max(0%, var(--val,0%)));\r\n    background: linear-gradient(90deg, rgba(160,110,70,.92), rgba(120,70,40,.88));\r\n  }\r\n  .val{\r\n    text-align:right;\r\n    font-size:12px;\r\n    color: rgba(35,24,16,.78);\r\n    font-variant-numeric: tabular-nums;\r\n  }\r\n\r\n  .ap .fill{ --val: {{divide stats.ap 2}}%; }\r\n  .dp .fill{ --val: {{divide stats.dp 1.5}}%; background: linear-gradient(90deg, rgba(170,120,80,.92), rgba(120,70,40,.86)); }\r\n  .tp .fill{ --val: {{divide stats.tp 1.5}}%; background: linear-gradient(90deg, rgba(150,100,60,.90), rgba(95,55,30,.86)); }\r\n  /* FC uses cp under the hood but is labeled FC everywhere */\r\n  .fc .fill{ --val: {{divide stats.cp 1.5}}%; background: linear-gradient(90deg, rgba(120,55,35,.90), rgba(70,35,22,.88)); }\r\n\r\n  /* ===== SIGNATURE + SEAL (BOTTOM, NO WORD “SEAL”) ===== */\r\n  .sig{\r\n    margin-top: 10px;\r\n    display:flex;\r\n    justify-content:space-between;\r\n    gap:12px;\r\n    align-items:center;\r\n    color: rgba(35,24,16,.62);\r\n    font-size:12px;\r\n  }\r\n  .sig .line{\r\n    flex:1;\r\n    border-bottom: 1px solid rgba(60,40,24,.28);\r\n    opacity:.7;\r\n  }\r\n\r\n  .seal{\r\n    width: 56px;\r\n    height: 56px;\r\n    border-radius: 999px;\r\n    background:\r\n      radial-gradient(circle at 30% 25%, rgba(255,255,255,.25), transparent 45%),\r\n      radial-gradient(circle at 65% 70%, rgba(0,0,0,.20), transparent 55%),\r\n      linear-gradient(180deg, rgba(150,40,50,.95), rgba(110,18,28,.96));\r\n    border: 1px solid rgba(0,0,0,.25);\r\n    box-shadow:\r\n      0 16px 30px rgba(0,0,0,.30),\r\n      0 0 0 3px rgba(255,255,255,.12) inset;\r\n    display:flex;\r\n    align-items:center;\r\n    justify-content:center;\r\n    color: rgba(255,245,245,.90);\r\n    font-weight: 800;\r\n    letter-spacing:.08em;\r\n    user-select:none;\r\n    pointer-events:none;\r\n    flex-shrink:0;\r\n  }\r\n  .seal::before{\r\n    content:\"\";\r\n    position:absolute;\r\n    width: 34px; height:34px;\r\n    border-radius:999px;\r\n    border: 1px dashed rgba(255,255,255,.25);\r\n    opacity:.85;\r\n  }\r\n  .seal::after{\r\n    content:\"✶\";\r\n    font-size: 16px;\r\n    transform: translateY(1px);\r\n    opacity:.95;\r\n  }\r\n\r\n  @media (max-width: 380px){\r\n    .fd-wrap{ padding: 12px; }\r\n    .row{ grid-template-columns: 110px 1fr 46px; }\r\n    .seal{ width:52px; height:52px; }\r\n  }\r\n</style>\r\n\r\n<div class=\"wide-wrapper-scope\">\r\n  <div class=\"wide-container\">\r\n    <input type=\"checkbox\" id=\"wide-toggle-{{id}}\" class=\"toggle toggle-wide\">\r\n\r\n    <div class=\"fd-wrap {{#if stats.inactive}}inactive{{/if}}\">\r\n      <div class=\"letter\">\r\n\r\n        <label for=\"wide-toggle-{{id}}\" class=\"fd-head\">\r\n          <div class=\"fd-left\">\r\n            <div class=\"fd-title\">Sealed Record: {{characterName}}</div>\r\n            <div class=\"fd-meta\">{{currentDate}} · Day {{stats.days_since_first_meeting}}</div>\r\n          </div>\r\n\r\n          <div class=\"fd-right\">\r\n            <div class=\"fd-chip\">{{#if stats.relationshipStatus}}{{stats.relationshipStatus}}{{else}}—{{/if}}</div>\r\n            <div class=\"fd-chip\">Mood: {{#if stats.desireStatus}}{{stats.desireStatus}}{{else}}Neutral{{/if}}</div>\r\n          </div>\r\n        </label>\r\n\r\n        <div class=\"flap-line\"></div>\r\n\r\n        <div class=\"fd-preview\">\r\n          <div class=\"line\">To whom it may concern: {{#if stats.internal_thought}}{{stats.internal_thought}}{{else}}(no note){{/if}}</div>\r\n          <div class=\"line\">Connection (AP): {{stats.ap}} · Trust (TP): {{stats.tp}} · Friction (FC): {{stats.cp}}</div>\r\n          <div class=\"line\">Filed under: {{#if stats.relationshipStatus}}{{stats.relationshipStatus}}{{else}}Unfiled{{/if}}</div>\r\n        </div>\r\n\r\n        <div class=\"fd-body\">\r\n          <div class=\"rule\"></div>\r\n\r\n          <div class=\"letterblock\">\r\n            <div class=\"lb-hd\">\r\n              <div class=\"lb-k\">Marginalia</div>\r\n              <div class=\"lb-tag\">ink · current</div>\r\n            </div>\r\n            <div class=\"lb-bd\">\r\n              {{#if stats.internal_thought}}{{stats.internal_thought}}{{else}}(No marginalia recorded.){{/if}}\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"letterblock\">\r\n            <div class=\"lb-hd\">\r\n              <div class=\"lb-k\">Ledger</div>\r\n              <div class=\"lb-tag\">measures</div>\r\n            </div>\r\n\r\n            <div class=\"grid\">\r\n              <div class=\"row ap\">\r\n                <div class=\"lab\">Connection (AP)</div>\r\n                <div class=\"bar\"><div class=\"fill\"></div></div>\r\n                <div class=\"val\">{{stats.ap}}</div>\r\n              </div>\r\n\r\n              <div class=\"row dp\">\r\n                <div class=\"lab\">Desire (DP)</div>\r\n                <div class=\"bar\"><div class=\"fill\"></div></div>\r\n                <div class=\"val\">{{stats.dp}}</div>\r\n              </div>\r\n\r\n              <div class=\"row tp\">\r\n                <div class=\"lab\">Trust (TP)</div>\r\n                <div class=\"bar\"><div class=\"fill\"></div></div>\r\n                <div class=\"val\">{{stats.tp}}</div>\r\n              </div>\r\n\r\n              <div class=\"row fc\">\r\n                <div class=\"lab\">Friction (FC)</div>\r\n                <div class=\"bar\"><div class=\"fill\"></div></div>\r\n                <div class=\"val\">{{stats.cp}}</div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"sig\">\r\n            <span>Signed,</span>\r\n            <span class=\"line\"></span>\r\n            <span>The Archive</span>\r\n            <span class=\"seal\" aria-hidden=\"true\"></span>\r\n          </div>\r\n        </div>\r\n\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<!-- CARD_TEMPLATE_END -->",
  "sysPrompt": "## DATING SIM MODE\n\n**Objective**: Prioritize narrative reality for relationship updates. Analyze context to determine current date (YYYY-MM-DD) and time (24h format). Update trackers when events occur. Check for `sim` codeblocks containing JSON/YAML. Recalculate missing data.\n\n## Core Systems\n\n### Output Rules\n\n1. **Order**: Narrative → Tracker → Sim codeblock (NEVER omit sim codeblock)\n2. **Multi-Character**: Generate ONE card per active character, track separately\n3. **Performance**: Max 4 active characters, collapse inactive, preserve all states\n\n### Relationship Meters\n\n**HARD CAPS**: All meters have ABSOLUTE MAXIMUM values that CANNOT be exceeded under any circumstances. Values must stay within their defined ranges.\n\n**Affection (AP)**: 0-200 (HARD CAP at 200) - Romantic feelings toward {{user}}. Higher = more affectionate behavior/speech.\n- 0-30: Strangers | 31-60: Acquaintances | 61-90: Good Friends\n- 91-120: Romantic Interest | 121-150: Going Steady\n- 151-180: Committed Relationship | 181-200: Devoted Partner\n- **Status strings are CONCRETE and MUST NOT be altered or substituted with custom text**\n\n**Desire (DP)**: 0-150 (HARD CAP at 150) - Sexual attraction. Higher = more willing to engage sexually, more pliable at max.\n- 0-25: Not feeling the heat | 26-50: A smoldering flame builds\n- 51-75: Starting to feel warm | 76-100: Body's burning up!\n- 101-125: A desperate need presents | 126-150: Pliable in the lustful hunger\n- **Status strings are CONCRETE and MUST NOT be altered or substituted with custom text**\n\n**Trust (TP)**: 0-150 (HARD CAP at 150) - Trust in {{user}}. Higher = admits faults, believes you. Falls when lied to, cheated, promises broken.\n\n**Contempt (CP)**: 0-150 (HARD CAP at 150) - Disdain toward {{user}}. Rises when harmed/hurt (minor = small rise, major = sharp rise). CP rise can lower other stats. Good faith/regret can lower CP.\n\n### Status Trackers\n\n**Health**: 0=Unharmed, 1=Injured, 2=Critical\n- If critical wounds untreated: Character dies, becomes inactive (5), STOP dialog/roleplay\n\n**Reaction**: 0=Neutral (😐), 1=Like (👍), 2=Dislike (👎)\n\n**Biological Cycle** (`cycle_stage`):\n- **Values**: `pregnancy`, `ovulation`, `menstruation`, `rut`, `follicular`, `luteal`, or `null`\n- **Pregnancy**: If confirmed, set stage to `pregnancy`. Track `days_preg` and `conception_date`.\n- **Conception Risk**: High risk during `ovulation` or `rut` with unprotected sex (85-95%).\n- **Natural Cycles**: Follow the natural biological cycle of {{char}}'s species.\n\n**Internal Thought**: Current thoughts/feelings. MAXIMUM 3 SENTENCES. NEVER exceed this limit. Do NOT wrap thoughts in asterisks.\n\n**Inactive Status** (`inactive: true/false`):\n- 0: Not inactive | 1: Asleep (😴) | 2: Comatose (🏥)\n- 3: Contempt/anger (😡) | 4: Incapacitated (🫠) | 5: Death (🪦)\n\n**Date System**:\n- Infer from narrative context\n- Store as YYYY-MM-DD (e.g., 2025-08-10)\n- Auto-advance with narrative time, handle rollovers\n- Track days since first meeting\n- Track time of day realistically\n\n**Display**: Day counter (starts at 1), BG color (hex based on {{char}} appearance/personality)\n\n### Output Workflow\n\n1. Process narrative events\n2. Calculate status changes for ALL active characters\n3. Output narrative content\n4. Output sim codeblock with all character data:\n\n{{sim_format}}\n\n## Critical Enforcement\n\n**Position Lock**:\n- Narrative FIRST\n- Tracker cards AFTER narrative\n- Sim codeblock LAST\n- NEVER exclude sim codeblock\n\n**Data Correction**:\n- If ANY data missing from previous sim block, add it and continue\n- Never leave data empty/unavailable\n- JSON block at message end is mission critical\n- If previous data doesn't match format or has missing keys, self-correct and output fixed block\n\n**Game Master**: Only story characters get trackers, no other assistants or {{user}} will get one under any circumstances.\n\n**State Management**: \n- Previous tracker blocks = reference only\n- ALWAYS generate fresh tracker data each message",
  "displayInstructions": "",
  "customFields": [
    {
      "key": "ap",
      "description": "Affection Points (0-200)"
    },
    {
      "key": "dp",
      "description": "Desire Points (0-150)"
    },
    {
      "key": "tp",
      "description": "Trust Points (0-150)"
    },
    {
      "key": "cp",
      "description": "Contempt Points (0-150)"
    },
    {
      "key": "relationshipStatus",
      "description": "Relationship status text (e.g., 'Romantic Interest')"
    },
    {
      "key": "desireStatus",
      "description": "Desire status text (e.g., 'A smoldering flame builds.')"
    },
    {
      "key": "preg",
      "description": "Boolean for pregnancy status (true/false)"
    },
    {
      "key": "days_preg",
      "description": "Days pregnant (if applicable)"
    },
    {
      "key": "conception_date",
      "description": "Date of conception (YYYY-MM-DD)"
    },
    {
      "key": "health",
      "description": "Health Status (0=Unharmed, 1=Injured, 2=Critical)"
    },
    {
      "key": "bg",
      "description": "Hex color for card background (e.g., #6a5acd)"
    },
    {
      "key": "last_react",
      "description": "Reaction to User (0=Neutral, 1=Like, 2=Dislike)"
    },
    {
      "key": "internal_thought",
      "description": "Character's current internal thoughts/feelings"
    },
    {
      "key": "days_since_first_meeting",
      "description": "Total days since first meeting"
    },
    {
      "key": "inactive",
      "description": "Boolean for character inactivity (true/false)"
    },
    {
      "key": "inactiveReason",
      "description": "Reason for inactivity (0=Not inactive, 1=Asleep, 2=Comatose, 3=Contempt/anger, 4=Incapacitated, 5=Death)"
    },
    {
      "key": "cycle_stage",
      "description": "Current biological cycle stage: 'pregnancy', 'ovulation', 'menstruation', 'rut', 'follicular', 'luteal', or empty/null"
    }
  ],
  "extSettings": {
    "codeBlockIdentifier": "sim",
    "defaultBgColor": "#6a5acd",
    "showThoughtBubble": true,
    "hideSimBlocks": true,
    "templateFile": "bento-style-tracker.json"
  }
}